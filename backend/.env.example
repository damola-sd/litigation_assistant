# Litigation Prep Assistant - Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================
# PART 1: AI / LLM
# ============================================================
# Your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Model to use for all agents (gpt-4o recommended)
OPENAI_MODEL=gpt-4o

# ============================================================
# PART 2: Database
# ============================================================
# Dev default — SQLite, no setup needed:
DATABASE_URL=sqlite+aiosqlite:///./litigation.db
# Prod Postgres (Sodiq wires this after DB is provisioned):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/litigation

# ============================================================
# PART 3: Auth (Clerk)
# ============================================================
# John / Sodiq wire these when Clerk is set up
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# ============================================================
# PART 4: CORS
# ============================================================
# JSON array of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]
